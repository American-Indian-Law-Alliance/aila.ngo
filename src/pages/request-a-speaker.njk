---
layout: page
title: "Request a Speaker"
description: "Request a speaker from the American Indian Law Alliance for events, conferences, trainings, or educational
programs. Submit your details at least one month in advance so our team can review availability, capacity, and alignment
with Indigenous rights, advocacy, and policy work."
date: 2026-04-09
---

<p>Thank you for your interest in connecting with us. Please include as much information as you can for each question.
  Note, that we ask for requests at least 1 month in advance of the event. The earlier, the better!</p>
<p>Filling out this form is not a guarantee we can meet your request, but it is the best way for us to evaluate our
  capacity and track your interest. We will get back to you as soon as possible.</p>

<form method="POST" action="{{ meta.forms.speakerFormUrl }}" class="form | region | stack" data-form="speaker">
  <!-- Contact Information -->
  <fieldset>
    <legend>Contact Information</legend>

    <div class="stack">
      <label for="contact-name">Contact Name</label>
      <input type="text" id="contact-name" placeholder="Name" name="Contact Name" required>
    </div>

    <div class="grid" data-layout="thirds">
      <div class="stack">
        <label for="email">Email</label>
        <input type="email" id="email" placeholder="email@example.com" name="Contact email" required>
      </div>

      <div class="stack">
        <label for="contact-phone">Contact Phone Number</label>
        <input type="tel" id="contact-phone" placeholder="(xxx)-xxx-xxxx" name="Contact Phone Number" required>
      </div>
    </div>
  </fieldset>


  <!-- Event Timing -->
  <fieldset>
    <legend>Date/Time Information</legend>
    <div class="stack">
      <label for="event-date">Date of your event</label>
      <input type="date" id="event-date" name="Event Date" required>
    </div>

    <div class="stack">
      <label for="event-time">Time of your event</label>
      <input type="time" id="event-time" name="Event Time" required>
    </div>

    <div class="stack">
      <label for="alt-date">Are there other dates and times that would work?</label>
      <input type="date" id="alt-date" name="Alternate Date" required>
    </div>
  </fieldset>


  <!-- Virtual Format -->
  <fieldset>
    <legend>Can this request take place in a virtual format?</legend>

    <label>
      <input type="radio" name="virtual_format" value="zoom" required>
      Yes – Zoom
    </label>

    <label>
      <input type="radio" name="virtual_format" value="other">
      Yes – Other Virtual Platform
    </label>

    <label>
      <input type="radio" name="virtual_format" value="no">
      No
    </label>
  </fieldset>

  <!-- Request Type -->
  <fieldset class="stack">
    <legend>What kind of request is this?</legend>

    <label for="request-type-singular"><input type="checkbox" id="request-type-singular" name="Request Type: Singular"
        value="singular" required>Speaker for singular event</label>
    <label for="request-type-multiple"><input type="checkbox" id="request-type-multiple"
        name="Request Type: Multiple Events" value="multiple">Speaker for multiple events</label>
    <label for="request-type-collaboration"><input type="checkbox" id="request-type-collaboration"
        name="Request Type: Collaboration/project" value="collaboration">Collaboration/project</label>
    <label for="request-type-interview"><input type="checkbox" id="request-type-interview"
        name="Request Type: Interview" value="interview">Interview</label>
    <label for="request-type-consultation"><input type="checkbox" id="request-type-consultation"
        name="Request Type: Consultation" value="consultation">Consultation</label>

    <label for="request-type-other">Other:</label>
    <input type="text" id="request-type-other" name="Request Type: Other">
    <div class="stack">
      <label for="request-description">
        Please describe your request (event, interview, project, consultation, collaboration, topic, etc.) *
      </label>
      <textarea id="request-description" name="Request Description" required></textarea>
    </div>
  </fieldset>

  <!-- Description Fields -->

  <div>
    <label for="org-description">
      Tell us about your organization, group, institution, corporation, etc. (if applicable) *
    </label>
    <textarea id="org-description" name="Organization Description" required></textarea>
  </div>

  <div>
    <label for="attendees">If applicable, how many attendees will be present? *</label>
    <input type="number" id="attendees" name="attendees" required>
  </div>

  <!-- Financial Contribution -->
  <div>
    <label for="financial-contribution">
      Please estimate your expected financial contribution:
    </label>
    <input type="text" id="financial-contribution" name="financial_contribution" required>
  </div>

  <!-- Tech Check -->
  <label for="tech-check">
    Will you require a tech check or preliminary meeting? If so, provide preferred dates/times.
  </label>
  <textarea id="tech-check" name="tech_check" required></textarea>

  <!-- Additional Info -->
  <label for="additional-info">Is there any other information that you would like to let us know?</label>
  <textarea id="additional-info" name="additional_info"></textarea>

  <button class="button | justify-center" type="submit" data-button-variant="secondary" style="inline-size: 10ch;">Submit</button>
</form>

{% css "local" %}
  {% include "css/forms.css" %}
{% endcss %}